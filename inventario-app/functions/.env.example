# Configuración de Odoo para integración de ventas

# URL de tu instancia Odoo (sin trailing slash)
ODOO_URL=https://tu-odoo.com

# Nombre de la base de datos en Odoo
ODOO_DB=nombre_db

# Usuario con acceso a Odoo (email o login)
ODOO_USER=usuario@email.com

# Contraseña del usuario
ODOO_PASSWORD=tu_contraseña_odoo

# Secreto compartido para validar webhooks (usar string aleatorio fuerte)
ODOO_WEBHOOK_SECRET=tu-secreto-aleatorio-muy-fuerte-aqui

# URL del webhook en Firebase Functions (se proporciona después del deploy)
# ODOO_WEBHOOK_URL=https://us-central1-tu-proyecto.cloudfunctions.net/odooWebhook
